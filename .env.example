# Required for AI enrichers (name normalization, area nicknames, custom agent, Sculptor)
OPENAI_API_KEY=sk-...

# Optional providers — pick in the UI settings
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override default model per provider
OPENAI_MODEL=gpt-4o-mini
PERPLEXITY_MODEL=sonar
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Default provider: openai | perplexity | anthropic
LLM_PROVIDER=openai

# Optional: enables Google Places enrichers (reviews, restaurants)
GOOGLE_PLACES_API_KEY=

# Supabase — durable storage for tables + API keys (recommended on Vercel)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Legacy fallback: Upstash Redis (optional if using Supabase)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
